{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hearth",
  "version": "0.1.0",
  "identifier": "com.lifedashboard.desktop",
  "build": {
    "beforeBuildCommand": "",
    "frontendDist": "../../web/out"
  },
  "app": {
    "windows": [
      {
        "title": "Hearth",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "url": "index.html",
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/life_dashboard_api"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "entitlements": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
