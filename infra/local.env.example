# ── Hearth — local install environment ────────────────────────────────
# Copy to infra/local.env and fill in your values before running:
#   ./infra/scripts/service.sh install

# ── Database ──────────────────────────────────────────────────────────────────
# For local Postgres installed by the install script (no Docker).
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/life_dashboard

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate once with:  python3 -c "import secrets; print(secrets.token_hex(32))"
# Never change after first run — it invalidates all existing sessions.
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info

# ── Telegram bot ─────────────────────────────────────────────────────────────
# Token from @BotFather. User ID from @userinfobot.
HEARTH_BOT_TOKEN=CHANGE_ME
HEARTH_BOT_USER_ID=CHANGE_ME

# ── CORS ──────────────────────────────────────────────────────────────────────
# The local web address. Extend with your Tailscale hostname if needed.
ALLOWED_ORIGINS=http://localhost:1337

# ── Web (read by Next.js at build and runtime) ────────────────────────────────
# Where the web process proxies API calls. Must match the API port above.
API_URL=http://127.0.0.1:1338
