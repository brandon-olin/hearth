# ── life-dashboard Caddyfile ───────────────────────────────────────────────────
#
# Caddy sits in front of the Next.js container and terminates TLS using the
# certificate that Tailscale provisions for this machine.
#
# Prerequisites (run once on the NAS):
#   sudo tailscale cert {$TS_HOSTNAME}
#
# The cert files land at /var/packages/Tailscale/var/certs/ on Synology DSM,
# which is bind-mounted into this container at /etc/caddy/certs (read-only).
#
# TS_HOSTNAME is read from infra/.env (e.g. nas.your-tailnet.ts.net).

{$TS_HOSTNAME} {
  # Use the Tailscale-issued certificate directly.
  # Caddy won't attempt ACME — the cert is already on disk.
  tls /etc/caddy/certs/{$TS_HOSTNAME}.crt /etc/caddy/certs/{$TS_HOSTNAME}.key

  # All traffic -> Next.js, which internally rewrites /api/* to the API
  # container. This keeps cookie handling identical to the local dev setup
  # (same-origin relative to the browser, no cross-origin cookie issues).
  reverse_proxy web:3000

  # Access log for debugging -- written to the named volume.
  log {
    output file /var/log/caddy/access.log {
      roll_size 10mb
      roll_keep 5
    }
  }
}

# Redirect bare HTTP to HTTPS.
http://{$TS_HOSTNAME} {
  redir https://{$TS_HOSTNAME}{uri} permanent
}
