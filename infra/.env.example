# ── Database ──────────────────────────────────────────────────────────────────
# Connection string for the Postgres instance.
# In Docker Compose, HOST is the container name and PORT is the internal port (5432).
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/life_dashboard

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Bootstrap ─────────────────────────────────────────────────────────────────
# Only used on first startup when the sentinel user still has password_hash '!'.
# The backend hashes this value, writes it to the DB, and effectively disables
# itself thereafter. Leave blank (or remove) after first successful boot.
BOOTSTRAP_PASSWORD=CHANGE_ME

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API.
# In production the frontend and API typically share the same origin (via Caddy).
ALLOWED_ORIGINS=https://YOUR_HOST

# ── Frontend (web/.env.local) ──────────────────────────────────────────────────
# Server-side env var read by next.config.ts to proxy /api/* to the backend.
# The Next.js process must be able to reach this URL directly (not via browser).
# Defaults to http://localhost:8000 if not set.
# API_URL=http://localhost:8000

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
LOG_LEVEL=info
