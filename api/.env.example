# ── Database ──────────────────────────────────────────────────────────────────
# Postgres (NAS / cloud) — asyncpg driver prefix required for SQLAlchemy async engine.
# NAS Postgres is exposed on 5433; adjust host when running inside Docker
# (use the container name, e.g. postgres-1, instead of the NAS LAN IP).
DATABASE_URL=postgresql+asyncpg://brandon:CHANGE_ME@192.168.68.58:5433/life_dashboard

# SQLite (local single-machine / desktop tier) — aiosqlite driver.
# Path is relative to the api/ directory; use an absolute path in production.
# Schema is created automatically on first boot (no alembic migrations needed).
# DATABASE_URL=sqlite+aiosqlite:///./life_dashboard.db

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE_ME

# HS256 is sufficient for a single-node local deployment.
JWT_ALGORITHM=HS256

# Access tokens are short-lived; the client silently refreshes using the
# refresh token stored in an httpOnly cookie.
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Bootstrap ─────────────────────────────────────────────────────────────────
# Used only on first startup when the sentinel user (brandon@life-dashboard.local)
# has the placeholder password_hash '!'. The backend will hash this value with
# argon2 and write it to the DB, then clear the env var from its own config.
# Leave blank after first run (or remove from your actual .env).
BOOTSTRAP_PASSWORD=your-password-here
BOOTSTRAP_EMAIL=your-email@here.local
BOOTSTRAP_DISPLAY_NAME=Your Name

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the frontend.
# Web / NAS: Next.js dev server on 1337, or the Tailscale hostname in production.
ALLOWED_ORIGINS=http://localhost:1337,http://localhost:1338

# Tauri desktop app: the Tauri WebView origin + localhost for dev tools.
# This is injected automatically by the Tauri sidecar in lib.rs — no need to
# set it manually. Shown here for reference only.
# ALLOWED_ORIGINS=tauri://localhost,http://localhost,http://localhost:1430

# ── AI ────────────────────────────────────────────────────────────────────────
# System-level Anthropic key. Used when a user has no BYOK key configured.
# Leave blank to disable AI features until a key is provided.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Teller bank sync ──────────────────────────────────────────────────────────
# Teller BYOK: each install supplies its own Teller application credentials.
# Hearth never proxies through a shared Teller account — your bank data stays
# entirely within your own Teller app and your own infrastructure.
#
# Setup steps:
#   1. Sign up at https://teller.io and create an application.
#   2. In your app's Settings, download the certificate bundle:
#      you'll get certificate.pem and private_key.pem.
#      Store them somewhere stable (e.g. ~/hearth-teller/ or a Docker secret).
#   3. Copy your App ID from the app's Settings page.
#   4. Add a webhook endpoint (TELLER_SIGNING_SECRET comes from that page).
#   5. Set TELLER_ENVIRONMENT to "development" when ready to test with real
#      (read-only) bank connections, or "sandbox" for Teller's test accounts.
#      Flip to "production" when you want live write-access transactions.
#
# Leave all blank to disable bank sync; the budget module works without it
# (manual CSV/OFX import continues to function normally).

TELLER_APP_ID=
# Absolute paths to the mTLS certificate files downloaded from the Teller dashboard.
TELLER_CERT_PATH=/path/to/certificate.pem
TELLER_KEY_PATH=/path/to/private_key.pem
# Webhook signing secret — found on the Webhooks page of your Teller app.
TELLER_SIGNING_SECRET=
# sandbox | development | production
TELLER_ENVIRONMENT=sandbox

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info

# Uvicorn bind address and port (used in the Dockerfile CMD).
HOST=0.0.0.0
PORT=1338
